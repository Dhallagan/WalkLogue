{
  "expo": {
    "name": "WalkLogue",
    "slug": "WalkLog",
    "scheme": "walklog",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FDFCF9"
    },
    "ios": {
      "supportsTablet": false,
      "appleTeamId": "XV3J6JJDVE",
      "bundleIdentifier": "com.dylan.walklog",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "WalkLogue uses the microphone to record your spoken journal entries during a walk.",
        "NSHealthUpdateUsageDescription": "WalkLogue saves step-related journal data to Apple Health when needed to support your walk entries.",
        "UIBackgroundModes": [
          "audio"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-av",
      [
        "@kingstinct/react-native-healthkit",
        {
          "background": false,
          "NSHealthShareUsageDescription": "WalkLogue reads your step count from Apple Health so each walk entry includes steps.",
          "NSHealthUpdateUsageDescription": "WalkLogue saves step-related journal data to Apple Health when needed to support your walk entries."
        }
      ],
      "expo-secure-store",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "d60bb496-d83e-41c0-9ca4-966d5ed9c868"
      }
    },
    "owner": "dhallagan",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/d60bb496-d83e-41c0-9ca4-966d5ed9c868"
    }
  }
}
